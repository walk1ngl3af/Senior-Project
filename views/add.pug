extends layout

block content
    div
        p Use this link to turn files into links
        a(href='https://www.image2url.com/file-to-url' target='_blank') ImageToUrl
    br
    form(action='/add' method='post')
        div.form-input
            label(for='name') Name:
            input(type='text' name='name' id='name')
        div.form-input
            label(for='description') Description:
            input(type='text' name='description' id='description' required)
        div.form-input
            label(for='image') Image:
            input(type='text' name='image' id='image')
        div.form-input
            label(for='type') Type of Animal
            select(name ='type' id='type' autocomplete='off' required)
                each type in types
                    option(value=type selected=(type === searchtype) autocomplete='off') #{type}
        div.form-input
            label(for='location') Last Known Location:
            input(type='text' name='location' id='location')
        div.form-input
            label(for='phone') Phone Number:
            input(type='text' name='phone' id='phone' required)
        div.form-input
            label(for='date') Day the Pet was Lost:
            input(type='text' id='date' name='date' placeholder='year-month-day')
        button.button(class="submit" type='submit') Submit
        a.button(class="cancel" href='/') Cancel